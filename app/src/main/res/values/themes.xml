<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        FIX [F5][P3]: tema oscuro coherente con el diseño de la app.
        Antes usaba android:Theme.Material.Light.NoActionBar (tema CLARO),
        lo que provocaba que la barra de estado y el splash fueran blancos,
        en contraste con el fondo oscuro (#1B1B2F) de todas las pantallas.
        Ahora usa el tema oscuro de Material para coherencia visual.
    -->
    <style name="Theme.Snake" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:statusBarColor">@color/background_dark</item>
        <item name="android:navigationBarColor">@color/background_dark</item>
    </style>
</resources>